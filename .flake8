[flake8]
max-line-length = 120
exclude =
    migrations,
    __pycache__,
    manage.py,
    settings,
    venv,
    env,
    backend/venv,
    backend/venv_new,
    backend/*/migrations,
    backend/posapi/settings,
    */node_modules,
    .git

ignore =
    E501,
    E302,
    E303,
    W391,
    W292,
    F401,
    E203,
    W503,
